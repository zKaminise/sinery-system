# =============================================================================
# Sinery System — LOCAL / desenvolvimento
# Copie para `.env.local` (NÃO comitado) e ajuste se precisar.
# Valores abaixo são seguros/fakes para o Postgres local (Docker na porta 5544).
# NUNCA coloque secrets reais aqui — este arquivo é versionado.
# =============================================================================

APP_ENV="local"
NODE_ENV="development"

DATABASE_URL="postgresql://sinery:sinery@localhost:5544/sinery_system?schema=public"

# Gere um real com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="local-development-secret-change-me-but-keep-32-plus-chars"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

DEFAULT_TENANT_SLUG="sorria-odonto"

# Bootstrap do founder (usado pelo seed).
PLATFORM_FOUNDER_EMAIL="founder@sinery.local"
PLATFORM_FOUNDER_TEMP_PASSWORD="Sinery@123"

# --- E-mail (Resend) — mock em dev ---
EMAIL_MOCK_MODE="true"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Sinery <no-reply@sinery.com.br>"
RESEND_REPLY_TO_EMAIL="kaminise@sinery.com.br"
RESEND_CONTACT_TO_EMAIL="kaminise@sinery.com.br"

# --- Recuperação de senha ---
PASSWORD_RESET_TOKEN_TTL_MINUTES="10"
PASSWORD_RESET_MAX_ATTEMPTS="5"
PASSWORD_RESET_CODE_LENGTH="6"
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS="60"

# --- Pagamento (Asaas) — mock em dev ---
ASAAS_ENABLED="true"
ASAAS_MOCK_MODE="true"
ASAAS_ENVIRONMENT="sandbox"
ASAAS_API_KEY=""
ASAAS_BASE_URL_SANDBOX="https://sandbox.asaas.com/api/v3"
ASAAS_BASE_URL_PRODUCTION="https://api.asaas.com/v3"
ASAAS_WEBHOOK_TOKEN="local-mock-webhook-token-change-me"
ASAAS_CHECKOUT_SUCCESS_URL="http://localhost:3000/checkout/sucesso"
ASAAS_CHECKOUT_CANCEL_URL="http://localhost:3000/checkout/cancelado"

# --- Checkout público ---
PUBLIC_CHECKOUT_ENABLED="true"
PUBLIC_CHECKOUT_ALLOWED_ORIGIN="http://localhost:3000,http://localhost:3001"
PUBLIC_CHECKOUT_RATE_LIMIT_PER_HOUR="20"

# --- IA (OpenAI) — rule-based em dev ---
ASSIST_USE_REAL_AI="false"
ASSIST_GLOBAL_DISABLED="false"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_TIMEOUT_MS="15000"
OPENAI_MAX_OUTPUT_TOKENS="800"
ASSIST_DAILY_TOKEN_LIMIT="100000"
ASSIST_MAX_HISTORY_MESSAGES="20"
ASSIST_RATE_LIMIT_PER_MINUTE="20"
ASSIST_RATE_LIMIT_PER_DAY="1000"
ASSIST_CONVERSATION_RATE_LIMIT_PER_MINUTE="10"
ASSIST_TOOL_RATE_LIMIT_PER_MINUTE="30"
ASSIST_MAX_TOOLS_PER_TURN="3"

# --- WhatsApp — mock em dev ---
WHATSAPP_CLOUD_API_ENABLED="true"
WHATSAPP_GRAPH_API_VERSION="v20.0"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID="123456789"
WHATSAPP_BUSINESS_ACCOUNT_ID="987654321"
WHATSAPP_APP_ID=""
WHATSAPP_APP_SECRET=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN="fake-verify"
WHATSAPP_WEBHOOK_PATH="/api/webhooks/whatsapp"
WHATSAPP_WEBHOOK_ENABLED="true"
WHATSAPP_VERIFY_SIGNATURE="false"
WHATSAPP_SEND_MESSAGES_ENABLED="true"
WHATSAPP_SEND_MOCK_MODE="true"
WHATSAPP_REQUIRE_24H_WINDOW="true"
WHATSAPP_AUTO_CREATE_PATIENT="false"
WHATSAPP_AUTO_PROCESS_ASSIST="true"
WHATSAPP_ASSIST_REPLY_ENABLED="true"
WHATSAPP_ASSIST_MOCK_MODE_ALLOWED="true"
WHATSAPP_ASSIST_MAX_AUTO_REPLIES_PER_CONVERSATION_PER_HOUR="20"
WHATSAPP_ASSIST_MAX_AUTO_REPLIES_PER_INBOUND="1"
WHATSAPP_ASSIST_PROCESSING_TIMEOUT_MS="20000"

# --- Observabilidade (Sentry) — opcional em dev ---
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
