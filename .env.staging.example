# =============================================================================
# Sinery System — HML / STAGING (homologação)
# Domínio: hml.app.sinery.com.br
# Estes valores são PLACEHOLDERS. Preencha os valores reais direto no painel da
# Vercel (Environment Variables) do projeto de HML — NÃO comite secrets.
# =============================================================================

APP_ENV="staging"
NODE_ENV="production"

# Neon (banco de HML — SEPARADO de produção). Use sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# EXCLUSIVO de HML (diferente de PRD). Gere com:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="generate-with-node-crypto-randombytes-48-base64url"

NEXT_PUBLIC_APP_URL="https://hml.app.sinery.com.br"
APP_URL="https://hml.app.sinery.com.br"
NEXT_PUBLIC_ROOT_DOMAIN="sinery.com.br"

DEFAULT_TENANT_SLUG=""

PLATFORM_FOUNDER_EMAIL="kaminise@sinery.com.br"
PLATFORM_FOUNDER_TEMP_PASSWORD="generate-a-strong-temporary-password"

# --- E-mail (Resend) — pode ser real em HML ---
EMAIL_MOCK_MODE="false"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Sinery <no-reply@sinery.com.br>"
RESEND_REPLY_TO_EMAIL="kaminise@sinery.com.br"
RESEND_CONTACT_TO_EMAIL="kaminise@sinery.com.br"

PASSWORD_RESET_TOKEN_TTL_MINUTES="10"
PASSWORD_RESET_MAX_ATTEMPTS="5"
PASSWORD_RESET_CODE_LENGTH="6"
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS="60"

# --- Asaas — começa em mock; troque para false para testar sandbox ---
ASAAS_ENABLED="true"
ASAAS_MOCK_MODE="true"
ASAAS_ENVIRONMENT="sandbox"
ASAAS_API_KEY=""
ASAAS_BASE_URL_SANDBOX="https://sandbox.asaas.com/api/v3"
ASAAS_BASE_URL_PRODUCTION="https://api.asaas.com/v3"
# Gere: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ASAAS_WEBHOOK_TOKEN="generate-random-webhook-token"
ASAAS_CHECKOUT_SUCCESS_URL="https://sinery.com.br/checkout/sucesso"
ASAAS_CHECKOUT_CANCEL_URL="https://sinery.com.br/checkout/cancelado"

PUBLIC_CHECKOUT_ENABLED="true"
PUBLIC_CHECKOUT_ALLOWED_ORIGIN="https://sinery.com.br,https://www.sinery.com.br"
PUBLIC_CHECKOUT_RATE_LIMIT_PER_HOUR="20"

# --- IA — começa false em HML ---
ASSIST_USE_REAL_AI="false"
ASSIST_GLOBAL_DISABLED="false"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_TIMEOUT_MS="15000"
OPENAI_MAX_OUTPUT_TOKENS="800"
ASSIST_DAILY_TOKEN_LIMIT="100000"
ASSIST_MAX_HISTORY_MESSAGES="20"

# --- WhatsApp — começa mock em HML ---
WHATSAPP_CLOUD_API_ENABLED="true"
WHATSAPP_GRAPH_API_VERSION="v20.0"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_APP_ID=""
WHATSAPP_APP_SECRET=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN="generate-random-whatsapp-verify-token"
WHATSAPP_WEBHOOK_PATH="/api/webhooks/whatsapp"
WHATSAPP_WEBHOOK_ENABLED="true"
WHATSAPP_VERIFY_SIGNATURE="false"
WHATSAPP_SEND_MESSAGES_ENABLED="true"
WHATSAPP_SEND_MOCK_MODE="true"
WHATSAPP_REQUIRE_24H_WINDOW="true"
WHATSAPP_AUTO_CREATE_PATIENT="false"
WHATSAPP_AUTO_PROCESS_ASSIST="false"
WHATSAPP_ASSIST_REPLY_ENABLED="false"
WHATSAPP_ASSIST_MOCK_MODE_ALLOWED="true"
WHATSAPP_ASSIST_MAX_AUTO_REPLIES_PER_CONVERSATION_PER_HOUR="20"
WHATSAPP_ASSIST_MAX_AUTO_REPLIES_PER_INBOUND="1"
WHATSAPP_ASSIST_PROCESSING_TIMEOUT_MS="20000"

# --- Observabilidade (Sentry) — ligar em HML ---
# DSN (não é segredo forte, mas fica só no painel/.local, não no template).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
