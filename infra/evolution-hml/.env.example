# =============================================================================
# Evolution API — Sinery HML — env template (Prompt 27)
# Copy to `.env` on the host and fill in REAL values there. NEVER commit `.env`.
# These are PLACEHOLDERS — no real secrets in this file.
#
# ⚠️  Verify the env-var NAMES against the exact Evolution API image tag you pin
#     (they differ between versions). See README.md → "Verify env names".
# =============================================================================

# ---- Image / ports ----------------------------------------------------------
# Pin an explicit version (do not use :latest in a shared environment).
EVOLUTION_IMAGE_TAG="v2.1.1"
# Host port that maps to the container's 8080.
EVOLUTION_HOST_PORT="8080"

# ---- Server -----------------------------------------------------------------
# Public HTTPS URL where this Evolution instance is reachable (behind your
# reverse proxy). Used by Evolution to build media/QR URLs.
SERVER_URL="https://evolution-hml.sinery.com.br"

# ---- Auth -------------------------------------------------------------------
# Global API key sent in the `apikey` header on every request. Generate a strong
# random value, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTHENTICATION_API_KEY="generate-a-strong-random-api-key"

# ---- PostgreSQL (persistence) -----------------------------------------------
POSTGRES_USER="evolution"
POSTGRES_PASSWORD="generate-a-strong-db-password"
POSTGRES_DB="evolution"
# Connection URI the Evolution container uses to reach the postgres service.
# Host is the compose service name `postgres`. Keep user/pass/db in sync above.
DATABASE_CONNECTION_URI="postgresql://evolution:generate-a-strong-db-password@postgres:5432/evolution?schema=public"

# ---- Redis (cache) ----------------------------------------------------------
CACHE_REDIS_URI="redis://redis:6379"

# ---- Logs -------------------------------------------------------------------
# ERROR | WARN | INFO | DEBUG (use ERROR/WARN in HML to keep logs quiet).
LOG_LEVEL="ERROR"

# ---- Session label (shown on the connected phone) ---------------------------
CONFIG_SESSION_PHONE_CLIENT="Sinery HML"
CONFIG_SESSION_PHONE_NAME="Chrome"

# ---- CORS -------------------------------------------------------------------
# Restrict to the hosts that call the Evolution API. `*` is acceptable only if
# the API is not publicly reachable; prefer an explicit list in HML.
CORS_ORIGIN="https://hml.app.sinery.com.br"

# =============================================================================
# NOTE — these are the SINERY-side env vars (set in Vercel HML, NOT here). Listed
# for reference so the two sides line up. See docs/environment-variables.md.
#   MESSAGING_PROVIDER=evolution
#   EVOLUTION_API_ENABLED=true
#   EVOLUTION_API_URL=<SERVER_URL above>
#   EVOLUTION_API_KEY=<AUTHENTICATION_API_KEY above>
#   EVOLUTION_INSTANCE_NAME=sinery-hml
#   EVOLUTION_WEBHOOK_SECRET=<random; also placed in the webhook URL ?token=>
#   EVOLUTION_WEBHOOK_PATH=/api/webhooks/evolution
# =============================================================================
