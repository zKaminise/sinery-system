# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real envs are NEVER committed (contain secrets).
# NOTE: production "cola" uses .env.prd.local (NOT .env.production.local), because
# `next build` (NODE_ENV=production) auto-loads .env.production.local and a local
# build would then hit the production DB. Both are covered by .env*.local below.
.env
.env.local
.env.staging.local
.env.production.local
.env.prd.local
.env*.local
# ...but the *.example templates ARE committed (no secrets, only placeholders).
!.env.example
!.env.local.example
!.env.staging.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# Sentry Config File
.env.sentry-build-plugin
