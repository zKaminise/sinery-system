// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ClinicSegment {
  ODONTOLOGY
  PHYSIOTHERAPY
  AESTHETICS
  PSYCHOLOGY
  MEDICAL
  OTHER
}

enum ClinicStatus {
  ACTIVE
  INACTIVE
  SETUP_PENDING
  SUSPENDED
}

enum UserRole {
  OWNER
  ADMIN
  RECEPTIONIST
  PROFESSIONAL
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProfessionalStatus {
  ACTIVE
  INACTIVE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum CreatedBySource {
  USER
  AI
  SYSTEM
}

enum ConversationChannel {
  WHATSAPP
  INTERNAL_SIMULATOR
}

enum ConversationStatus {
  AI_HANDLING
  WAITING_HUMAN
  HUMAN_HANDLING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageSenderType {
  PATIENT
  AI
  HUMAN
  SYSTEM
}

enum MessageDeliveryStatus {
  INTERNAL_ONLY
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  MOCK_SENT
}

// ---------------------------------------------------------------------------
// Tenant root
// ---------------------------------------------------------------------------

/// Each Clinic is a tenant of the Sinery System SaaS. Every operational model
/// below carries a clinicId so all queries can (and must) be scoped by tenant.
model Clinic {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  legalName String?
  document  String?
  segment   ClinicSegment @default(ODONTOLOGY)
  email     String?
  phone     String?
  whatsapp  String?
  address   String?
  city      String?
  state     String?
  logoUrl   String?
  status    ClinicStatus  @default(SETUP_PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  settings             ClinicSettings?
  aiSettings           AiSettings?
  users                User[]
  patients             Patient[]
  professionals        Professional[]
  services             Service[]
  workingHours         WorkingHour[]
  appointments         Appointment[]
  conversations        Conversation[]
  messages             Message[]
  knowledgeBase        AiKnowledgeBase[]
  aiUsageLogs          AiUsageLog[]
  auditLogs            AuditLog[]
  professionalServices ProfessionalService[]
  whatsAppIntegration  WhatsAppIntegration?
  whatsAppWebhookEvents WhatsAppWebhookEvent[]
  assistProcessingRuns  AssistProcessingRun[]

  // Commercial / billing (Prompt 21 — Founder/Platform admin).
  subscription         ClinicSubscription?
  billingInvoices      BillingInvoice[]
  billingEvents        BillingEvent[]
  billingNotifications BillingNotificationLog[]

  // Email + checkout (Prompt 22).
  emailLogs        EmailLog[]
  checkoutSessions CheckoutSession[]

  @@index([status])
}

/// Per-clinic operational configuration (business hours, slot size, AI toggles).
model ClinicSettings {
  id                     String   @id @default(cuid())
  clinicId               String   @unique
  timezone               String   @default("America/Sao_Paulo")
  businessStartHour      Int?
  businessEndHour        Int?
  appointmentSlotMinutes Int      @default(30)
  allowAiScheduling      Boolean  @default(false)
  allowAiRescheduling    Boolean  @default(false)
  allowAiCancellation    Boolean  @default(false)
  aiTone                 String   @default("professional")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

/// System users. No real authentication yet — passwordHash/status fields are
/// modeled now so the auth prompt can slot in without a schema migration.
///
/// Email uniqueness is scoped per clinic (clinicId + email), not global,
/// because the same person's email may legitimately need an account in more
/// than one clinic (e.g. a professional who works at two partner clinics).
model User {
  id                String     @id @default(cuid())
  clinicId          String
  name              String
  email             String
  passwordHash      String?
  role              UserRole   @default(RECEPTIONIST)
  status            UserStatus @default(INVITED)
  temporaryPassword Boolean    @default(false)
  firstLoginAt      DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  clinic                Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdAppointments   Appointment[]  @relation("AppointmentCreatedByUser")
  assignedConversations Conversation[] @relation("ConversationAssignedUser")
  auditLogs             AuditLog[]
  emailLogs             EmailLog[]
  passwordResetTokens   PasswordResetToken[]

  @@unique([clinicId, email])
}

// ---------------------------------------------------------------------------
// Core clinic data
// ---------------------------------------------------------------------------

model Patient {
  id        String        @id @default(cuid())
  clinicId  String
  name      String
  phone     String
  email     String?
  document  String?
  birthDate DateTime?
  notes     String?
  source    String?
  status    PatientStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  conversations Conversation[]

  @@index([clinicId, phone])
}

model Professional {
  id        String             @id @default(cuid())
  clinicId  String
  name      String
  email     String?
  phone     String?
  specialty String?
  status    ProfessionalStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  clinic       Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  workingHours WorkingHour[]
  appointments Appointment[]
  services     ProfessionalService[]

  @@index([clinicId, name])
}

model Service {
  id              String        @id @default(cuid())
  clinicId        String
  name            String
  description     String?
  durationMinutes Int
  priceInCents    Int?
  status          ServiceStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clinic        Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  professionals ProfessionalService[]

  @@index([clinicId, name])
}

/// Join table linking which professionals perform which services. Used by
/// the future Agenda module to know which professionals can be offered for a
/// given service. Both sides are always validated against the current
/// clinicId before linking — see app/api/professionals/[professionalId]/services.
model ProfessionalService {
  id             String   @id @default(cuid())
  clinicId       String
  professionalId String
  serviceId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([professionalId, serviceId])
  @@index([clinicId])
  @@index([serviceId])
  @@index([professionalId])
}

/// Weekly recurring availability per professional. dayOfWeek follows
/// JavaScript's Date#getDay() convention: 0 = Sunday ... 6 = Saturday.
/// startTime/endTime are stored as "HH:mm" strings to keep the model simple
/// and timezone-agnostic; ClinicSettings.timezone is the source of truth for
/// interpreting them.
model WorkingHour {
  id             String   @id @default(cuid())
  clinicId       String
  professionalId String
  dayOfWeek      Int
  startTime      String
  endTime        String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([professionalId])
}

model Appointment {
  id              String            @id @default(cuid())
  clinicId        String
  patientId       String
  professionalId  String
  serviceId       String?
  title           String?
  startAt         DateTime
  endAt           DateTime
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?
  createdByUserId String?
  createdBySource CreatedBySource   @default(USER)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("AppointmentCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([clinicId, startAt])
}

// ---------------------------------------------------------------------------
// Conversations (future WhatsApp / Sinery Assist panel)
// ---------------------------------------------------------------------------

model Conversation {
  id                String              @id @default(cuid())
  clinicId          String
  patientId         String?
  channel           ConversationChannel @default(INTERNAL_SIMULATOR)
  externalContactId String?
  contactName       String?
  contactPhone      String?
  status            ConversationStatus  @default(AI_HANDLING)
  assignedUserId    String?
  /// Free-form per-conversation state. Used by the Sinery Assist simulator to
  /// persist deterministic flow state (assistFlow: intent/step/detected data/
  /// suggested slots) between messages, since there is no real AI/session.
  metadata          Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  clinic       Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient?  @relation(fields: [patientId], references: [id], onDelete: SetNull)
  assignedUser User?     @relation("ConversationAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages     Message[]
  assistProcessingRuns AssistProcessingRun[]

  @@index([clinicId, contactPhone])
}

model Message {
  id             String            @id @default(cuid())
  clinicId       String
  conversationId String
  direction      MessageDirection
  senderType     MessageSenderType
  content        String
  metadata       Json?
  // External-channel provenance (WhatsApp, etc.). Null for internal messages.
  externalMessageId String?
  externalChannel   String?
  externalTimestamp DateTime?
  // Outbound delivery lifecycle (Prompt 18). Null for internal messages.
  deliveryStatus       MessageDeliveryStatus?
  deliveryErrorCode    String?
  deliveryErrorMessage String?
  sentAt               DateTime?
  deliveredAt          DateTime?
  readAt               DateTime?
  failedAt             DateTime?
  createdAt      DateTime          @default(now())

  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  assistInboundRuns  AssistProcessingRun[] @relation("AssistInboundMessage")
  assistOutboundRuns AssistProcessingRun[] @relation("AssistOutboundMessage")

  @@index([clinicId])
  @@index([conversationId])
  @@index([externalMessageId])
  @@index([externalChannel])
  @@index([deliveryStatus])
}

// ---------------------------------------------------------------------------
// Sinery Assist (AI)
// ---------------------------------------------------------------------------

model AiSettings {
  id                   String   @id @default(cuid())
  clinicId             String   @unique
  assistantName        String   @default("Sinery Assist")
  enabled              Boolean  @default(false)
  tone                 String   @default("professional")
  fallbackToHuman      Boolean  @default(true)
  humanFallbackMessage String?
  canAnswerPricing     Boolean  @default(false)
  canSchedule          Boolean  @default(false)
  canReschedule        Boolean  @default(false)
  canCancel            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model AiKnowledgeBase {
  id        String   @id @default(cuid())
  clinicId  String
  title     String
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

/// Per-message record of AI provider usage for the Sinery Assist, used for
/// simple cost control (daily token limit) and usage metrics. `provider` is
/// "OPENAI" or "RULE_BASED"; token counts are best-effort (null when unknown).
/// Never stores prompt/message content or any secret.
model AiUsageLog {
  id                   String   @id @default(cuid())
  clinicId             String
  conversationId       String?
  provider             String
  mode                 String?
  model                String?
  inputTokens          Int?
  outputTokens         Int?
  totalTokens          Int?
  estimatedCostInCents Int?
  success              Boolean  @default(true)
  errorCode            String?
  errorMessage         String?
  latencyMs            Int?
  toolName             String?
  createdAt            DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, createdAt])
  @@index([clinicId, success])
  @@index([clinicId, provider])
}

// ---------------------------------------------------------------------------
// WhatsApp Cloud API integration (Prompt 16 — preparatory only)
// ---------------------------------------------------------------------------

enum WhatsAppIntegrationStatus {
  NOT_CONFIGURED
  CONFIGURED
  INVALID_CONFIG
  DISABLED
  READY_FOR_WEBHOOK
  READY_FOR_SEND
  ERROR
}

/// Per-clinic WhatsApp integration metadata. NEVER stores the access token,
/// app secret, or webhook verify token — those live only in server-side env.
/// Only booleans/non-sensitive ids are persisted here.
model WhatsAppIntegration {
  id       String @id @default(cuid())
  clinicId String @unique
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  enabled  Boolean @default(false)
  provider String  @default("META_CLOUD_API")

  businessAccountId String?
  phoneNumberId     String?
  appId             String?

  displayPhoneNumber String?
  verifiedName       String?

  webhookPath                  String?
  webhookVerifyTokenConfigured Boolean @default(false)

  sendMessagesEnabled Boolean @default(false)
  webhookEnabled      Boolean @default(false)

  status                 WhatsAppIntegrationStatus @default(NOT_CONFIGURED)
  lastConfigCheckAt      DateTime?
  lastConfigCheckStatus  String?
  lastConfigCheckMessage String?

  lastWebhookVerifiedAt DateTime?
  lastMessageReceivedAt DateTime?
  lastMessageSentAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  webhookEvents WhatsAppWebhookEvent[]

  @@index([status])
  @@index([enabled])
}

/// One row per received WhatsApp webhook event. Guarantees idempotency via a
/// unique payloadHash (Meta re-delivers). NEVER stores the raw payload or any
/// secret — only a hash + non-sensitive summary fields.
model WhatsAppWebhookEvent {
  id String @id @default(cuid())

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  integrationId String?
  integration   WhatsAppIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  eventType         String
  whatsappMessageId String?
  whatsappStatusId  String?
  phoneNumberId     String?
  fromPhone         String?
  payloadHash       String

  processed    Boolean @default(false)
  ignored      Boolean @default(false)
  errorCode    String?
  errorMessage String?

  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([payloadHash])
  @@index([clinicId])
  @@index([integrationId])
  @@index([eventType])
  @@index([whatsappMessageId])
  @@index([phoneNumberId])
  @@index([receivedAt])
}

enum AssistProcessingStatus {
  PENDING
  RUNNING
  SENT
  INTERNAL_ONLY
  TRANSFERRED_TO_HUMAN
  SKIPPED
  FAILED
}

/// One row per inbound WhatsApp message the Sinery Assist processes.
/// `@@unique([inboundMessageId])` guarantees a single auto-reply per inbound
/// (idempotency for webhook re-delivery / double triggers). No prompt/payload.
model AssistProcessingRun {
  id String @id @default(cuid())

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  inboundMessageId String
  inboundMessage   Message @relation("AssistInboundMessage", fields: [inboundMessageId], references: [id], onDelete: Cascade)

  outboundMessageId String?
  outboundMessage   Message? @relation("AssistOutboundMessage", fields: [outboundMessageId], references: [id], onDelete: SetNull)

  mode         String
  trigger      String?
  status       AssistProcessingStatus @default(PENDING)
  reason       String?
  intent       String?
  confidence   Float?
  errorCode    String?
  errorMessage String?

  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([inboundMessageId])
  @@index([clinicId])
  @@index([conversationId])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

model AuditLog {
  id          String   @id @default(cuid())
  clinicId    String?
  userId      String?
  action      String
  entity      String
  entityId    String?
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clinicId, createdAt])
}

// ---------------------------------------------------------------------------
// Platform / Founder admin (Prompt 21)
// ---------------------------------------------------------------------------

/// Platform-level operator of the Sinery SaaS (the founder + future staff).
/// NOT a clinic user: has no clinicId, uses a separate session cookie, and can
/// only reach /founder routes. Never mixed with the per-clinic User model.
model PlatformUser {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  passwordHash      String
  role              PlatformRole       @default(FOUNDER)
  status            PlatformUserStatus @default(ACTIVE)
  temporaryPassword Boolean            @default(true)
  passwordChangedAt DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  emailLogs           EmailLog[]
  passwordResetTokens PasswordResetToken[]
}

enum PlatformRole {
  FOUNDER
  PLATFORM_ADMIN
  SUPPORT
  FINANCE
}

enum PlatformUserStatus {
  ACTIVE
  INACTIVE
}

/// A commercial plan offered to clinics. Prices are integer cents.
model Plan {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  priceInCents Int    @default(0)
  currency     String @default("BRL")

  billingInterval BillingInterval @default(MONTHLY)

  maxUsers                    Int?
  maxProfessionals            Int?
  maxPatients                 Int?
  maxAppointmentsPerMonth     Int?
  maxAiMessagesPerMonth       Int?
  maxWhatsappMessagesPerMonth Int?

  includesWhatsapp Boolean @default(false)
  includesAi       Boolean @default(false)

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions    ClinicSubscription[]
  checkoutSessions CheckoutSession[]
}

enum BillingInterval {
  FREE
  MONTHLY
  YEARLY
  ONE_TIME
  CUSTOM
}

/// One subscription per clinic (the commercial relationship). Manual billing
/// only in V1 — no real payment provider yet.
model ClinicSubscription {
  id String @id @default(cuid())

  clinicId String @unique
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id], onDelete: SetNull)

  status SubscriptionStatus @default(TRIALING)

  billingType   BillingType   @default(MANUAL)
  paymentMethod PaymentMethod @default(MANUAL)

  amountInCents Int    @default(0)
  currency      String @default("BRL")

  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  nextDueDate        DateTime?

  graceDays    Int       @default(20)
  overdueSince DateTime?
  suspendedAt  DateTime?
  cancelledAt  DateTime?

  freeReason    String?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices BillingInvoice[]

  @@index([status])
  @@index([nextDueDate])
}

enum SubscriptionStatus {
  FREE
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXEMPT
}

enum BillingType {
  MANUAL
  CHECKOUT
  API
  EXTERNAL
}

enum PaymentMethod {
  MANUAL
  PIX
  BOLETO
  CREDIT_CARD
  BANK_TRANSFER
  FREE
  OTHER
}

/// A billing invoice (manual in V1). External* fields are placeholders for a
/// future Asaas/Stripe integration.
model BillingInvoice {
  id String @id @default(cuid())

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  subscriptionId String?
  subscription   ClinicSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  invoiceNumber String?

  status        InvoiceStatus @default(PENDING)
  paymentMethod PaymentMethod @default(MANUAL)

  amountInCents Int
  currency      String @default("BRL")

  dueDate     DateTime
  paidAt      DateTime?
  cancelledAt DateTime?

  externalProvider   String?
  externalInvoiceId  String?
  externalPaymentUrl String?

  manualPaymentReference String?
  internalNotes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
  MANUALLY_CONFIRMED
}

/// Append-only commercial event log for a clinic (created invoice, marked paid,
/// suspended, etc.). Human-readable trail visible in the founder panel.
model BillingEvent {
  id String @id @default(cuid())

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  subscriptionId String?
  invoiceId      String?

  type     String
  message  String?
  metadata Json?

  createdByPlatformUserId String?
  createdAt               DateTime @default(now())

  @@index([clinicId])
  @@index([subscriptionId])
  @@index([invoiceId])
  @@index([type])
}

/// Preview/log of a billing notification. In V1 nothing is actually sent — rows
/// stay PENDING/MOCKED. A future Resend integration will flip these to SENT.
model BillingNotificationLog {
  id String @id @default(cuid())

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  invoiceId String?
  type      BillingNotificationType

  status BillingNotificationStatus @default(PENDING)

  recipientEmail String
  subject        String?
  preview        String?

  sentAt       DateTime?
  failedAt     DateTime?
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([invoiceId])
  @@index([type])
  @@index([status])
}

enum BillingNotificationType {
  PAYMENT_DUE_SOON
  PAYMENT_DUE_TODAY
  PAYMENT_OVERDUE
  PAYMENT_SUSPENSION_WARNING
  PAYMENT_SUSPENDED
  PAYMENT_CONFIRMED
}

enum BillingNotificationStatus {
  PENDING
  MOCKED
  SENT
  FAILED
}

/// Platform-level audit trail (founder actions). Separate from the per-clinic
/// AuditLog because these actions are not scoped to a single tenant.
model PlatformAuditLog {
  id String @id @default(cuid())

  platformUserId String?
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?

  createdAt DateTime @default(now())

  @@index([platformUserId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Transactional email + password reset (Prompt 22)
// ---------------------------------------------------------------------------

/// One row per transactional email attempt (Resend or mock). Never stores the
/// email body's sensitive parts (codes/passwords) — only subject + safe metadata.
model EmailLog {
  id String @id @default(cuid())

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  platformUserId String?
  platformUser   PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: SetNull)

  toEmail      String
  fromEmail    String
  replyToEmail String?
  subject      String
  type         EmailType
  status       EmailStatus @default(PENDING)

  provider          EmailProvider @default(RESEND)
  providerMessageId String?
  errorMessage      String?
  metadata          Json?

  createdAt DateTime  @default(now())
  sentAt    DateTime?
  failedAt  DateTime?

  @@index([clinicId])
  @@index([userId])
  @@index([platformUserId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

enum EmailType {
  PASSWORD_RESET_CODE
  OWNER_WELCOME_FOUNDER
  OWNER_WELCOME_CHECKOUT
  TEMPORARY_PASSWORD_RESET
  BILLING_PAYMENT_CONFIRMED
  BILLING_PAYMENT_OVERDUE
  CHECKOUT_PAYMENT_PENDING
  CONTACT_FORM
}

enum EmailStatus {
  PENDING
  MOCKED
  SENT
  FAILED
}

enum EmailProvider {
  RESEND
  MOCK
}

/// A password reset request. The 6-digit code is stored ONLY as a hash. Single
/// use, expiring, with an attempt limit. Works for clinic Users and PlatformUsers.
model PasswordResetToken {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platformUserId String?
  platformUser   PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  email     String
  tokenHash String

  expiresAt DateTime
  usedAt    DateTime?

  attempts    Int @default(0)
  maxAttempts Int @default(5)

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([userId])
  @@index([platformUserId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Public checkout / onboarding (Asaas) — Prompt 22
// ---------------------------------------------------------------------------

/// A self-service checkout started by the marketing site. The Clinic is only
/// created AFTER payment is confirmed (via the Asaas webhook). The desired slug
/// is reserved while AWAITING_PAYMENT.
model CheckoutSession {
  id       String @id @default(cuid())
  publicId String @unique

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id], onDelete: SetNull)

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  status CheckoutSessionStatus @default(PENDING)

  clinicName      String
  desiredSlug     String
  ownerName       String
  ownerEmail      String
  ownerPhone      String?
  companyDocument String?
  city            String?
  state           String?

  amountInCents   Int
  currency        String          @default("BRL")
  billingInterval BillingInterval

  externalProvider       String?
  externalCustomerId     String?
  externalSubscriptionId String?
  externalPaymentId      String?
  externalPaymentUrl     String?

  paidAt    DateTime?
  expiresAt DateTime?

  errorMessage String?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([ownerEmail])
  @@index([desiredSlug])
  @@index([externalProvider])
  @@index([externalSubscriptionId])
  @@index([externalPaymentId])
}

enum CheckoutSessionStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  PROVISIONING
  PROVISIONED
  FAILED
  CANCELLED
  EXPIRED
}

/// Idempotency + audit for payment-provider webhooks (Asaas). `payloadHash`
/// unique guarantees a re-delivered event is never processed twice.
model PaymentProviderEvent {
  id String @id @default(cuid())

  provider               String
  eventType              String
  externalEventId        String?
  externalPaymentId      String?
  externalSubscriptionId String?
  checkoutSessionId      String?
  clinicId               String?

  payloadHash String  @unique
  processed   Boolean @default(false)
  ignored     Boolean @default(false)

  errorCode    String?
  errorMessage String?

  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@index([provider])
  @@index([eventType])
  @@index([externalPaymentId])
  @@index([externalSubscriptionId])
  @@index([checkoutSessionId])
  @@index([clinicId])
}
