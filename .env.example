# =============================================================================
# Sinery System — ÍNDICE de variáveis de ambiente
# =============================================================================
# Este arquivo é o template UNIVERSAL (referência de todas as variáveis).
# Por ambiente, use os templates específicos e copie para o arquivo *.local
# correspondente (que NUNCA é comitado):
#
#   Local/dev :  cp .env.local.example       .env.local
#   HML       :  cp .env.staging.example     .env.staging.local   (ou envs na Vercel)
#   Produção  :  cp .env.production.example   .env.prd.local       (ou envs na Vercel)
#
# ⚠️  Produção usa `.env.prd.local`, NÃO `.env.production.local`!
#     `next build` roda com NODE_ENV=production e carrega `.env.production.local`
#     automaticamente — se o DATABASE_URL real de produção estivesse lá, o build
#     LOCAL apontaria para o banco de produção. Use `.env.prd.local` (ignorado
#     pelo Next, mas coberto pelo .gitignore em `.env*.local`).
#
# Em desenvolvimento local, o Next carrega `.env.local` e `.env` automaticamente.
# Em HML/Produção na Vercel, as variáveis vêm do painel (Environment Variables),
# NÃO de arquivos .local (que a Vercel não usa).
# `APP_ENV` (local | staging | production) é a fonte de verdade do ambiente.
# Detalhes: docs/environment-variables.md e docs/deploy-staging.md.
# NUNCA comite segredos — apenas os arquivos *.example são versionados.
# =============================================================================

# Copy this file to .env (or .env.local) and fill in the values for your setup.
# Never commit the real .env / *.local files — covered by .gitignore.

# PostgreSQL connection string.
# - Local via Docker (docker-compose.yml in this repo): the URL below works as-is.
#   The container is published on host port 5544 (not 5432) to avoid clashing
#   with a native PostgreSQL install that may already own 5432 on Windows.
# - Free hosted Postgres (Neon, Supabase, etc.): paste the connection string they give you.
DATABASE_URL="postgresql://sinery:sinery@localhost:5544/sinery_system?schema=public"

# Public app URL, used for links generated by the app (e.g. absolute URLs in emails).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Root domain used to resolve a clinic's subdomain in production
# (e.g. "sorria-odonto" is extracted from "sorria-odonto.sinery.com.br").
# In local development this stays as "localhost:3000" and is not used to
# resolve the tenant — DEFAULT_TENANT_SLUG is used instead.
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# Clinic slug used as a fallback to resolve "the current clinic" when there's
# no logged-in user yet. Must match a Clinic.slug in the database (the seed
# script creates "sorria-odonto"). Once logged in, the user's own clinic
# (from the session) always takes priority over this.
DEFAULT_TENANT_SLUG="sorria-odonto"

# Secret key used to sign/verify the session JWT (jose). REQUIRED — the app
# throws a clear error if this is missing when a session is created or read.
# Generate a real one locally with: openssl rand -base64 32
# Never commit a real secret; "change-me-in-development" is a placeholder only.
AUTH_SECRET="change-me-in-development"

# Name of the HTTP-only session cookie.
SESSION_COOKIE_NAME="sinery_session"

# Session lifetime in seconds. 604800 = 7 days.
SESSION_MAX_AGE_SECONDS="604800"

# --- Founder / Platform admin (Prompt 21) ---
# The founder panel (/founder) uses a SEPARATE session cookie from the clinic
# session (both signed with AUTH_SECRET; the platform token carries a distinct
# claim so they can't be swapped). Both optional — sensible defaults below.
SESSION_PLATFORM_COOKIE_NAME="sinery_platform_session"
SESSION_PLATFORM_MAX_AGE_SECONDS="86400"

# --- Observability (Sentry) ------------------------------------------------
# All Sentry variables are OPTIONAL. Leave them empty to run the app with no
# error reporting — nothing breaks, Sentry simply stays uninitialized.
#
# Server-side DSN (error capture in Server Components, Route Handlers, etc.).
SENTRY_DSN=""
# Client-side DSN, exposed to the browser bundle (must be NEXT_PUBLIC_*).
# Usually the same value as SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=""
# Only needed to upload source maps during CI builds (not required to run).
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- Sinery Assist AI (OpenAI) ---------------------------------------------
# ALL optional. With OPENAI_API_KEY empty OR ASSIST_USE_REAL_AI=false, the
# Sinery Assist runs the deterministic rule-based simulator (Prompt 12) and
# nothing breaks. Real AI runs only when ASSIST_USE_REAL_AI=true AND
# OPENAI_API_KEY is set. NEVER expose OPENAI_API_KEY to the browser or logs.
#
# Your OpenAI API key. Leave empty to force rule-based mode.
# Special dev/test value "mock" runs the AI code path OFFLINE (no network,
# no cost) using a deterministic stub — useful to exercise the real-AI flow.
OPENAI_API_KEY=""
# Chat model id. If empty, a documented safe default is used (gpt-4o-mini).
# Use "mock" together with OPENAI_API_KEY="mock" for offline testing.
OPENAI_MODEL=""
# Per-request timeout (ms) for the OpenAI call.
OPENAI_TIMEOUT_MS="20000"
# Max output tokens per AI reply.
OPENAI_MAX_OUTPUT_TOKENS="800"
# Master switch for real AI. "false" keeps the rule-based simulator even if a
# key is present.
ASSIST_USE_REAL_AI="false"
# Simple per-clinic per-day token budget; when exceeded, falls back to rules.
ASSIST_DAILY_TOKEN_LIMIT="100000"
# Max recent messages sent to the model as conversation history.
ASSIST_MAX_HISTORY_MESSAGES="20"

# --- Sinery Assist safety & cost controls (Prompt 15) ---
# GLOBAL kill switch. "true" disables ALL Assist automation (rules + AI) and
# forces a human transfer. UI shows "Sinery Assist desativada globalmente".
ASSIST_GLOBAL_DISABLED="false"
# Rate limits (DB-based, no Redis). Counted from AiUsageLog/messages.
ASSIST_RATE_LIMIT_PER_MINUTE="20"
ASSIST_RATE_LIMIT_PER_DAY="1000"
ASSIST_CONVERSATION_RATE_LIMIT_PER_MINUTE="10"
ASSIST_TOOL_RATE_LIMIT_PER_MINUTE="30"
# Max tool executions the AI may trigger in a single turn (loop guard).
ASSIST_MAX_TOOLS_PER_TURN="3"

# --- WhatsApp Cloud API (Prompt 16 — PREPARATORY; no send/webhook yet) ---
# ALL optional. The app runs fine with these empty ("WhatsApp não configurado").
# SECRETS (ACCESS_TOKEN, APP_SECRET, WEBHOOK_VERIFY_TOKEN) are read ONLY on the
# server, NEVER sent to the browser, NEVER logged, NEVER stored in the DB.
WHATSAPP_CLOUD_API_ENABLED="false"
WHATSAPP_GRAPH_API_VERSION="v20.0"
# Sensitive — server-only. Never commit real values.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_APP_ID=""
# Sensitive — used later to validate the webhook signature (Prompt 17).
WHATSAPP_APP_SECRET=""
# Sensitive — used later for Meta's webhook handshake (Prompt 17).
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_WEBHOOK_PATH="/api/webhooks/whatsapp"
# Envio real (Prompt 18) — mantenha "false" neste prompt.
WHATSAPP_SEND_MESSAGES_ENABLED="false"
# Recebimento real (Prompt 17). "true" ativa o GET (handshake) e o POST do
# webhook. Com "false", GET/POST respondem 403 sem processar.
WHATSAPP_WEBHOOK_ENABLED="false"
# Optional read-only Graph config check. Keep "false" (no external call).
WHATSAPP_ALLOW_CONFIG_LIVE_CHECK="false"
# Valida a assinatura HMAC (X-Hub-Signature-256) com o APP_SECRET. Mantenha
# "true"; use "false" APENAS em dev local (mostra alerta na UI/status).
WHATSAPP_VERIFY_SIGNATURE="true"
# Criar Patient automaticamente ao receber de número desconhecido. Mantenha
# "false" (Prompt 17 apenas associa por telefone quando há match único).
WHATSAPP_AUTO_CREATE_PATIENT="false"
# Disparar a Sinery Assist automaticamente ao receber um inbound WhatsApp em
# AI_HANDLING. Mantenha "false" em produção até validar os testes.
WHATSAPP_AUTO_PROCESS_ASSIST="false"

# --- Resposta automática da Sinery Assist no WhatsApp (Prompt 19) ---
# "true" permite ENVIAR a resposta da Assist pelo WhatsApp. "false" gera a
# resposta apenas internamente (deliveryStatus INTERNAL_ONLY, sem Graph API).
WHATSAPP_ASSIST_REPLY_ENABLED="false"
# Permite usar o mock de envio para as respostas da Assist em dev.
WHATSAPP_ASSIST_MOCK_MODE_ALLOWED="true"
# Limite de respostas automáticas por conversa por hora (anti-flood/loop).
WHATSAPP_ASSIST_MAX_AUTO_REPLIES_PER_CONVERSATION_PER_HOUR="20"
# No máximo N respostas automáticas por mensagem inbound (mantenha 1).
WHATSAPP_ASSIST_MAX_AUTO_REPLIES_PER_INBOUND="1"
# Timeout do processamento síncrono da Assist no webhook.
WHATSAPP_ASSIST_PROCESSING_TIMEOUT_MS="20000"

# --- Envio real de texto (Prompt 18) ---
# "true" simula o envio (gera externalMessageId mock, deliveryStatus MOCK_SENT)
# SEM chamar a Graph API. Ótimo para dev sem token real.
WHATSAPP_SEND_MOCK_MODE="false"
# Timeout (ms) da chamada de envio à Graph API.
WHATSAPP_SEND_TIMEOUT_MS="15000"
# "true" só permite texto livre se houve mensagem do paciente nas últimas 24h
# (janela de atendimento). Mantenha "true"; "false" só em dev (mostra alerta).
WHATSAPP_REQUIRE_24H_WINDOW="true"

# --- E-mail transacional (Resend) — Prompt 22 ------------------------------
# Server-only. Com EMAIL_MOCK_MODE=true nada é enviado (EmailLog fica MOCKED).
# RESEND_API_KEY nunca vai para o browser/bundle nem para logs.
RESEND_API_KEY=""
# Remetente (via Resend). Não precisa existir como caixa postal real.
RESEND_FROM_EMAIL="Sinery <no-reply@sinery.com.br>"
# Respostas vão para este endereço real.
RESEND_REPLY_TO_EMAIL="kaminise@sinery.com.br"
# Destino do formulário de contato (futuro).
RESEND_CONTACT_TO_EMAIL="kaminise@sinery.com.br"
# "true" = não chama o Resend (dev/testes). "false" = envia de verdade.
EMAIL_MOCK_MODE="true"

# --- Recuperação de senha (Prompt 22) --------------------------------------
PASSWORD_RESET_TOKEN_TTL_MINUTES="10"
PASSWORD_RESET_MAX_ATTEMPTS="5"
PASSWORD_RESET_CODE_LENGTH="6"
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS="60"

# --- Pagamento / checkout (Asaas) — Prompt 22 ------------------------------
# Server-only. ASAAS_ENABLED=false bloqueia integração real; ASAAS_MOCK_MODE=true
# simula customer/subscription/payment sem chamar o Asaas.
ASAAS_ENABLED="false"
ASAAS_MOCK_MODE="true"
ASAAS_ENVIRONMENT="sandbox"
ASAAS_API_KEY=""
ASAAS_BASE_URL_SANDBOX="https://sandbox.asaas.com/api/v3"
ASAAS_BASE_URL_PRODUCTION="https://api.asaas.com/v3"
# Token validado no header asaas-access-token do webhook. NUNCA igual à API key.
ASAAS_WEBHOOK_TOKEN=""
ASAAS_CHECKOUT_SUCCESS_URL=""
ASAAS_CHECKOUT_CANCEL_URL=""

# --- Checkout público (site → sistema) — Prompt 22 -------------------------
# PUBLIC_CHECKOUT_ENABLED=false bloqueia o endpoint público de checkout.
PUBLIC_CHECKOUT_ENABLED="false"
# Origin permitido para CORS do checkout público (ex.: https://sinery.com.br).
PUBLIC_CHECKOUT_ALLOWED_ORIGIN=""
PUBLIC_CHECKOUT_RATE_LIMIT_PER_HOUR="20"

# --- Mensageria: provider + Evolution API (Prompt 24) ----------------------
# Provider padrão da clínica: "meta_cloud" (produção, API oficial da Meta) ou
# "evolution" (HML/local, via Evolution API). Evolution é BLOQUEADA em produção
# por padrão (só roda com EVOLUTION_ALLOW_IN_PRODUCTION=true, com aviso crítico).
# EVOLUTION_API_KEY e EVOLUTION_WEBHOOK_SECRET são server-only — nunca no client.
MESSAGING_PROVIDER="meta_cloud"
EVOLUTION_API_ENABLED="false"
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE_NAME=""
EVOLUTION_WEBHOOK_SECRET=""
EVOLUTION_WEBHOOK_PATH="/api/webhooks/evolution"
EVOLUTION_WEBHOOK_ENABLED="false"
EVOLUTION_SEND_MESSAGES_ENABLED="false"
EVOLUTION_SEND_MOCK_MODE="true"
EVOLUTION_AUTO_PROCESS_ASSIST="false"
EVOLUTION_ASSIST_REPLY_ENABLED="false"
EVOLUTION_PROCESSING_TIMEOUT_MS="20000"
EVOLUTION_ALLOW_IN_PRODUCTION="false"
